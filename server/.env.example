# Copy to server/.env — file must live in the server/ folder next to package.json.
# No spaces around =. Use straight quotes only if the value has spaces.

# Local SQLite (default). On Render, DATABASE_URL is set by the platform.
DATABASE_URL=file:./dev.db

JWT_SECRET=your-super-secret-jwt-key-change-this
PORT=3000

# AI Provider: openai | anthropic | gemini | google (same as gemini)
# If unset, the first provider with a key is used (Gemini checked first).
AI_PROVIDER=gemini

# Paste your real key on one line (no sk-... placeholder)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Optional overrides
# OPENAI_MODEL=gpt-4o-mini
# ANTHROPIC_MODEL=claude-3-haiku-20240307
# Default in code is gemini-2.5-flash. Override if your key/region lists other ids (AI Studio → List models).
# GEMINI_MODEL=gemini-2.5-flash-lite
