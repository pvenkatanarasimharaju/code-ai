# Copy to server/.env — file must live in the server/ folder next to package.json.

# PostgreSQL (local Docker, Neon, Supabase, or Render DATABASE_URL)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"
JWT_SECRET=your-super-secret-jwt-key-change-this
#DATABASE_URL="file:./dev.db"
#JWT_SECRET="dev-jwt-secret-change-in-production"
PORT=3000

# ─── AI Provider API Keys ─────────────────────────────────
# Add one or more keys below. Providers are auto-detected
# from whichever keys are present. If multiple keys are set,
# you can pick the provider/model in the chat UI dropdown.
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ─── Optional: Override default model per provider ────────
# If unset, built-in defaults are used (shown in the dropdown).
# A custom value here is prepended to the model dropdown list.
# GEMINI_MODEL=gemini-2.5-flash
# OPENAI_MODEL=gpt-4o-mini
# ANTHROPIC_MODEL=claude-3-haiku-20240307

# ─── Optional: Gemini thinking mode ──────────────────────
# Gemini 2.5 models support "thinking" mode. Default: false
# GEMINI_USE_THINKING=false
